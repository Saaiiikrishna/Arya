# ─── Database ─────────────────────────────────────────
# IMPORTANT: In production, use Azure Key Vault or managed identity
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/arya?schema=public"
PRISMA_DATASOURCE_URL="postgresql://USER:PASSWORD@HOST:PORT/arya?schema=public"

# ─── Redis ────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT ──────────────────────────────────────────────
# IMPORTANT: Generate secure random secrets for production (min 32 chars)
# Use: openssl rand -hex 32
JWT_SECRET=generate-a-secure-random-string-here-min-32-chars
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=generate-another-secure-random-string-here-min-32-chars
JWT_REFRESH_EXPIRATION=7d

# ─── AWS ──────────────────────────────────────────────
# IMPORTANT: Use IAM roles in production, never commit real credentials
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_SES_FROM_EMAIL=noreply@yourdomain.com
AWS_S3_BUCKET=your-s3-bucket-name

# ─── App ──────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
BATCH_CAPACITY=1000

# ─── Google Auth ──────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Razorpay ─────────────────────────────────────────
# IMPORTANT: Never commit real API keys. Use environment injection in CI/CD
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=generate-a-secure-webhook-secret-here
